# Backend Environment Variables
# Database
DATABASE_URL=postgresql://mspl:mspl123@localhost:5432/mspl_db
DB_USER=mspl
DB_PASSWORD=mspl123
DB_NAME=mspl_db
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_12345
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_12345
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Server
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=mspl-uploads
S3_REGION=us-east-1

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@msplservice.com

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp Configuration (stub)
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_SECRET=your_session_secret_change_in_production
